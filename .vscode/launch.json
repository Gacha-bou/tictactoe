{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Bot",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ts-node", "${workspaceFolder}/src/index.ts"],
      "program": "${workspaceFolder}/src/index.ts",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "tsc: build - tsconfig.json"
    }
  ]
}
